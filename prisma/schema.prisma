generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin") // "super_admin" or "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications              Notification[]
  leaveRequestsCreated       LeaveRequest[]       @relation("CreatedBy")
  leaveRequestsReviewed      LeaveRequest[]       @relation("ReviewedBy")
  cancellationRequestsCreated CancellationRequest[] @relation("RequestedBy")
  cancellationRequestsReviewed CancellationRequest[] @relation("ReviewedBy")
  warnings                   Warning[]
  fines                      Fine[]
}

model Employee {
  id               String    @id @default(cuid())
  fullName         String
  employeeId       String    @unique
  nationality      String?
  dateOfBirth      DateTime?
  phone            String?
  email            String?
  address          String?
  emergencyContact String?
  position         String?
  joinDate         DateTime?
  companyName      String?
  passportNumber   String?
  passportStatus   String?
  idNumber         String?
  idStatus         String?
  currentSite      String?
  rating           Float     @default(0)
  status           String    @default("active") // "active", "deleted", "pending_deletion"
  photo            String?
  isTeamLeader     Boolean   @default(false)
  teamLeaderSiteId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  attendance           Attendance[]
  warnings             Warning[]
  fines                Fine[]
  leaveRequests        LeaveRequest[]
  cancellationRequests CancellationRequest[]
  uniformRegistry      UniformRegistry[]
}

model Site {
  id          String   @id @default(cuid())
  name        String   @unique
  clientName  String?
  projectName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Attendance {
  id            String   @id @default(cuid())
  employeeId    String
  date          String   // YYYY-MM-DD format
  status        String   @default("not_marked") // "present", "absent", "no_site", "overtime", "not_marked"
  overtimeHours Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "request", "warning", "fine"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Warning {
  id              String   @id @default(cuid())
  employeeId      String
  reason          String
  isAutoGenerated Boolean  @default(false)
  absentDates     String?  // JSON string of dates
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])
}

model Fine {
  id         String   @id @default(cuid())
  employeeId String
  reason     String
  amount     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
}

model LeaveRequest {
  id            String    @id @default(cuid())
  employeeId    String
  leaveType     String    // "casual", "sick", "annual", "emergency", "marriage", "other"
  otherTypeText String?   // Free-text when leaveType is "other"
  startDate     DateTime
  endDate       DateTime
  totalDays     Int
  reason        String
  status        String    @default("pending") // "pending", "approved", "rejected"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviewedAt    DateTime?

  employee      Employee @relation(fields: [employeeId], references: [id])
  createdById   String
  createdBy     User     @relation("CreatedBy", fields: [createdById], references: [id])
  reviewedById  String?
  reviewedBy    User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
}

model CancellationRequest {
  id             String    @id @default(cuid())
  employeeId     String
  reason         String?
  status         String    @default("pending") // "pending", "approved", "rejected"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  reviewedAt     DateTime?

  employee       Employee @relation(fields: [employeeId], references: [id])
  requestedById  String
  requestedBy    User     @relation("RequestedBy", fields: [requestedById], references: [id])
  reviewedById   String?
  reviewedBy     User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
}

model UniformRegistry {
  id             String   @id @default(cuid())
  tokenNumber    Int      @unique
  employeeName   String
  employeeId     String
  documentType   String   // "id" or "passport"
  documentNumber String
  items          String   // JSON string: e.g. '{"uniform":true,"shoes":false,"helmet":true,"bottle":false,"safetyJacket":true}'
  siteName       String?
  teamLeaderName String?
  isRenewal      Boolean  @default(false)
  previousTokenId String? // reference to previous token if this is a renewal
  createdAt      DateTime @default(now())
  renewalDate    DateTime // 6 months from createdAt

  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([tokenNumber])
  @@index([createdAt])
}
