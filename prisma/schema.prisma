generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin") // "super_admin" or "admin"
  theme     String   @default("dark") // "dark" or "light"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications              Notification[]
  leaveRequestsCreated       LeaveRequest[]       @relation("CreatedBy")
  leaveRequestsReviewed      LeaveRequest[]       @relation("ReviewedBy")
  cancellationRequestsCreated CancellationRequest[] @relation("RequestedBy")
  cancellationRequestsReviewed CancellationRequest[] @relation("ReviewedBy")
  warnings                   Warning[]
  fines                      Fine[]
  menuPermissions            AdminMenuPermission[]
  adminPermissions           AdminPermission[]
}

model AdminMenuPermission {
  id        String   @id @default(cuid())
  userId    String
  menuKey   String  // e.g. "employees", "sites", "attendance", "leave_requests", "cancellation_requests", "notifications"
  allowed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, menuKey])
  @@index([userId])
}

model Employee {
  id               String    @id @default(cuid())
  fullName         String
  employeeId       String    @unique
  nationality      String?
  dateOfBirth      DateTime?
  phone            String?
  email            String?
  address          String?
  emergencyContact String?
  position         String?   // Legacy - kept for backward compat
  trade            String?   // New: Trade (Mason, Electrician, Welder, etc.)
  joinDate         DateTime?
  companyName      String?
  passportNumber   String?
  passportStatus   String?
  idNumber         String?
  idStatus         String?
  currentSite      String?
  rating           Float     @default(0)
  status           String    @default("active") // "active", "deleted", "pending_deletion"
  photo            String?
  isTeamLeader     Boolean   @default(false)
  teamLeaderSiteId String?
  isSupervisor     Boolean   @default(false)
  supervisorSiteId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  attendance           Attendance[]
  warnings             Warning[]
  fines                Fine[]
  leaveRequests        LeaveRequest[]
  cancellationRequests CancellationRequest[]
  uniformRegistry      UniformRegistry[]
  siteHistory          EmpCountSitePerMonth[]
  salaryRecords        SalaryRecord[]
  workingHours         TotalEmployeeWorkingHours?

  @@index([trade])
  @@index([isTeamLeader])
  @@index([isSupervisor])
  @@index([currentSite])
}

model Site {
  id          String   @id @default(cuid())
  name        String   @unique
  clientName  String?
  projectName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  employeeHistory EmpCountSitePerMonth[]
}

model Attendance {
  id            String   @id @default(cuid())
  employeeId    String
  date          String   // YYYY-MM-DD format
  status        String   @default("present") // "present", "absent", "no_site", "overtime", "not_marked"
  overtimeHours Float?
  isHidden      Boolean  @default(false) // Soft-hide when employee is deleted
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([isHidden])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // "request", "warning", "fine"
  read      Boolean  @default(false)
  isHidden  Boolean  @default(false) // Soft-hide when employee is deleted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isHidden])
}

model Warning {
  id              String   @id @default(cuid())
  employeeId      String
  reason          String
  isAutoGenerated Boolean  @default(false)
  absentDates     String?  // JSON string of dates
  isHidden        Boolean  @default(false) // Soft-hide when employee is deleted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])

  @@index([employeeId])
  @@index([isHidden])
}

model Fine {
  id         String   @id @default(cuid())
  employeeId String
  reason     String
  amount     Float
  isHidden   Boolean  @default(false) // Soft-hide when employee is deleted
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([employeeId])
  @@index([isHidden])
}

model LeaveRequest {
  id            String    @id @default(cuid())
  employeeId    String
  leaveType     String    // "casual", "sick", "annual", "emergency", "marriage", "other"
  otherTypeText String?   // Free-text when leaveType is "other"
  startDate     DateTime
  endDate       DateTime
  totalDays     Int
  reason        String
  status        String    @default("pending") // "pending", "approved", "rejected"
  isHidden      Boolean   @default(false) // Soft-hide when employee is deleted
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviewedAt    DateTime?

  employee      Employee @relation(fields: [employeeId], references: [id])
  createdById   String
  createdBy     User     @relation("CreatedBy", fields: [createdById], references: [id])
  reviewedById  String?
  reviewedBy    User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
  @@index([isHidden])
}

model CancellationRequest {
  id             String    @id @default(cuid())
  employeeId     String
  reason         String?
  status         String    @default("pending") // "pending", "approved", "rejected"
  isHidden       Boolean   @default(false) // Soft-hide when employee is deleted
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  reviewedAt     DateTime?

  employee       Employee @relation(fields: [employeeId], references: [id])
  requestedById  String
  requestedBy    User     @relation("RequestedBy", fields: [requestedById], references: [id])
  reviewedById   String?
  reviewedBy     User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
  @@index([isHidden])
}

model UniformRegistry {
  id             String   @id @default(cuid())
  uniformId      Int      @unique // Separate ID field for reuse when deleting main record
  tokenNumber    Int
  employeeName   String
  employeeId     String
  documentType   String   // "id" or "passport"
  documentNumber String   // Stored encrypted
  items          String   // JSON string: e.g. '{"uniform":true,"shoes":false,"helmet":true,"bottle":false,"safetyJacket":true}'
  siteName       String?
  teamLeaderName String?
  isRenewal      Boolean  @default(false)
  previousTokenId String? // reference to previous token if this is a renewal
  isDeleted      Boolean  @default(false)
  isHidden       Boolean  @default(false) // Soft-hide when employee is deleted
  createdAt      DateTime @default(now())
  renewalDate    DateTime // 6 months from createdAt

  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([tokenNumber])
  @@index([createdAt])
  @@index([uniformId])
  @@index([isHidden])
}

model Permission {
  id        String   @id @default(cuid())
  name      String   @unique // Display name: "Dashboard", "Employees", etc.
  slug      String   @unique // URL key: "dashboard", "employees", etc.
  group     String   @default("general") // Permission group: "general", "workforce", "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminPermissions AdminPermission[]

  @@index([slug])
  @@index([group])
}

model AdminPermission {
  id           String   @id @default(cuid())
  adminId      String
  permissionId String
  createdAt    DateTime @default(now())

  admin      User       @relation(fields: [adminId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([adminId, permissionId])
  @@index([adminId])
  @@index([permissionId])
}

model TotalEmployeeWorkingHours {
  id               String   @id @default(cuid())
  empId            String   @unique // FK to Employee
  empName          String
  totalWorkingHours Float  @default(0) // total accumulated hours
  rtPerHour        Float    @default(2.5) // rate per hour (auto-calculated or custom)
  isCustom         Boolean  @default(false) // if true, rtPerHour is manually set
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee Employee @relation(fields: [empId], references: [id], onDelete: Cascade)

  @@index([empId])
}

model SalaryRecord {
  id           String   @id @default(cuid())
  empId        String   // FK to Employee
  empName      String
  siteId       String   // FK to Site
  siteName     String
  month        String   // YYYY-MM format
  year         Int
  nationality  String   @default("")
  trade        String   @default("")
  employeeCode String   @default("") // employeeId (e.g. ASM-001)
  slNo         Int      @default(0)
  totalHours   Float    @default(0)
  rtPerHour    Float    @default(2.5)
  totalSalary  Float    @default(0)
  deduction    Float    @default(0)
  advance      Float    @default(0)
  balanceSalary Float   @default(0)
  isPaid       Boolean  @default(false)
  isDeleted    Boolean  @default(false) // soft delete
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [empId], references: [id], onDelete: Cascade)

  @@unique([empId, siteId, month, year])
  @@index([empId])
  @@index([siteId])
  @@index([month])
  @@index([year])
  @@index([siteId, month, year])
  @@index([isPaid])
}

model EmpCountSitePerMonth {
  id          String    @id @default(cuid())
  empId       String    // referenced from Employee table
  empName     String    // name of the employee
  siteId      String    // referenced from Site table
  siteName    String    // name of the site
  month       String    // which month the employee worked there (YYYY-MM format)
  createdDate DateTime  @default(now()) // when added to site
  removedDate DateTime? // when removed from site (null if still at site)
  updatedDate DateTime  @updatedAt
  deletedDate DateTime? // soft delete timestamp

  employee Employee @relation(fields: [empId], references: [id], onDelete: Cascade)
  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([empId])
  @@index([siteId])
  @@index([month])
  @@index([empId, siteId])
}
